<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Instax — Phase 1</title>
    <style>
        * { margin: 0; padding: 0; }
        body {
            margin: 0;
            overflow: hidden;
            background: #000;
            height: 100vh;
        }
        canvas { display: block; }
    </style>
</head>
<body>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.162.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.162.0/examples/jsm/"
        }
    }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { SVGLoader } from 'three/addons/loaders/SVGLoader.js';

        // --- renderer ---
        var renderer = new THREE.WebGLRenderer({ antialias: false, alpha: false, powerPreference: 'high-performance' });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.prepend(renderer.domElement);

        // --- scene ---
        var scene = new THREE.Scene();
        scene.background = new THREE.Color(0xFFF0F5);

        // --- camera (orthographic, pixel-mapped) ---
        var W2 = window.innerWidth / 2;
        var H2 = window.innerHeight / 2;
        var camera = new THREE.OrthographicCamera(-W2, W2, H2, -H2, -1000, 1000);

        function pixelToWorld(px, py) {
            return {
                x: px - W2,
                y: H2 - py
            };
        }

        // --- render ---
        function render() {
            renderer.render(scene, camera);
        }

        // --- flower hierarchy containers ---
        var flowerGroup = null;
        var container = new THREE.Group();
        scene.add(container);

        var allPetalMeshes = [];
        var allStamenMeshes = [];
        var allAntherMeshes = [];
        var allStigmaMeshes = [];


        var svgScale = 1;

        // --- physics state (preserved from original) ---
        var state = 'FROZEN';
        var x = Math.random() * (window.innerWidth * 0.4) + window.innerWidth * 0.3;
        var y = -120;
        var velocityX = 0;
        var velocityY = 0;
        var rotation = 0;
        var rafId = null;


        var GRAVITY = 0.012;
        var TERMINAL_V = 0.5;
        var WIND_AMP = 3.5;
        var WIND_FREQ = 0.0015;
        var DAMPING = 0.95;
        var REST_DELTA = 0.04;
        var CENTER_Y = window.innerHeight * (0.33 + Math.random() * 0.33);
        var ROTATION_SPEED = 0.8;
        var IDLE_WIND_AMP = 1.2;
        var IDLE_BOB_AMP = 0.25;


        var loaded = false;
        var pendingFall = false;

        // --- breathing ---
        var breathPhase = 0;

        //#explaining_the_function# Resolve gradient definitions from SVG XML
        function resolveGradients(xml) {
            var SVG_NS = 'http://www.w3.org/2000/svg';
            var XLINK_NS = 'http://www.w3.org/1999/xlink';
            var grads = {};
            var defs = xml.querySelector('defs');
            if (!defs) {
                console.warn('resolveGradients: no defs found');
                // Try getElementsByTagNameNS as fallback
                var defsNS = xml.getElementsByTagNameNS(SVG_NS, 'defs');
                if (defsNS.length > 0) defs = defsNS[0];
            }
            if (!defs) { console.warn('resolveGradients: still no defs'); return grads; }
            var gradientEls = Array.from(defs.querySelectorAll('linearGradient, radialGradient'));
            if (gradientEls.length === 0) {
                // Fallback: NS-aware
                gradientEls = Array.from(defs.getElementsByTagNameNS(SVG_NS, 'linearGradient'));
                var radialEls = Array.from(defs.getElementsByTagNameNS(SVG_NS, 'radialGradient'));
                gradientEls = gradientEls.concat(radialEls);
            }
            // First pass: collect stop definitions
            gradientEls.forEach(function(g) {
                var id = g.getAttribute('id');
                var stopEls = Array.from(g.querySelectorAll ? g.querySelectorAll('stop') : []);
                if (stopEls.length === 0) stopEls = Array.from(g.getElementsByTagNameNS(SVG_NS, 'stop'));
                var stops = [];
                stopEls.forEach(function(s) {
                    var style = s.getAttribute('style') || '';
                    var stopColor = s.getAttribute('stop-color');
                    if (!stopColor && style) {
                        var m = style.match(/stop-color:\s*([^;]+)/);
                        if (m) stopColor = m[1];
                    }
                    var stopOpacity = s.getAttribute('stop-opacity');
                    if (!stopOpacity && style) {
                        var m = style.match(/stop-opacity:\s*([^;]+)/);
                        if (m) stopOpacity = m[1];
                    }
                    var color = stopColor || '#888';
                    var opacity = parseFloat(stopOpacity) || 1;
                    stops.push({ color: color, opacity: opacity });
                });
                grads[id] = stops;
            });
            // Second pass: resolve xlink:href references
            gradientEls.forEach(function(g) {
                var id = g.getAttribute('id');
                if (grads[id] && grads[id].length > 0) return;
                var found = false;
                ['getAttributeNS', 'getAttribute(href)', 'getAttribute(xlink:href)'].forEach(function(m) {
                    var h = m === 'getAttributeNS' ? g.getAttributeNS(XLINK_NS, 'href') : (m === 'getAttribute(href)' ? g.getAttribute('href') : g.getAttribute('xlink:href'));
                    if (h && h.startsWith('#')) {
                        var refId = h.slice(1);
                        if (grads[refId]) { grads[id] = grads[refId]; found = true; }
                    }
                });
                if (!found) {
                    console.warn('FAILED to resolve gradient', id);
                }
            });
            return grads;
        }

        //#explaining_the_function# Compute a representative solid color from gradient stops
        function averageGradientColor(stops) {
            if (!stops || stops.length === 0) return new THREE.Color('#888');
            var r = 0, g = 0, b = 0, totalWeight = 0;
            for (var i = 0; i < stops.length; i++) {
                var c = new THREE.Color(stops[i].color);
                var w = stops[i].opacity;
                r += c.r * w;
                g += c.g * w;
                b += c.b * w;
                totalWeight += w;
            }
            if (totalWeight === 0) return new THREE.Color('#888');
            var result = new THREE.Color(r / totalWeight, g / totalWeight, b / totalWeight);
            return result;
        }

        //#explaining_the_function# Build explicit flower hierarchy from SVGLoader paths + XML
        function buildHierarchy(data) {
            var paths = data.paths;
            var xml = data.xml;
            var gradients = resolveGradients(xml);

            // Group paths by parent <g> id
            var groupMap = { Petals: [], Stigma: [], Stamens: [], Anthers: [] };
            var groupNames = { Petals: true, Stigma: true, Stamens: true, Anthers: true };

            paths.forEach(function(path) {
                var node = path.userData.node;
                // Walk up to find parent <g>
                var parent = node.parentNode;
                while (parent && parent.nodeName !== 'g') {
                    parent = parent.parentNode;
                }
                var groupId = parent ? parent.getAttribute('id') : null;
                if (!groupId || !groupNames[groupId]) return;

                // Resolve fill color
                var fillStyle = path.userData.style.fill;
                var color;
                if (fillStyle && typeof fillStyle === 'string' && fillStyle.startsWith('url(')) {
                    var gradId = fillStyle.replace(/^url\(["']?#/, '').replace(/["']?\)$/, '');
                    var gradData = gradients[gradId];
                    if (!gradData) { console.warn('grad not found:', gradId); color = new THREE.Color('#888'); }
                    else if (gradData.length === 0) { console.warn('grad empty:', gradId); color = new THREE.Color('#888'); }
                    else {
                        color = averageGradientColor(gradData);
                    }
                } else if (fillStyle && fillStyle !== 'none') {
                    color = new THREE.Color(fillStyle);
                } else {
                    return; // skip elements with no fill
                }

                // Convert ShapePath → Shape(s) → geometry
                var shapes = SVGLoader.createShapes(path);
                if (shapes.length === 0) return;

                // Build geometry with holes
                var shape = shapes[0];
                for (var s = 1; s < shapes.length; s++) {
                    shape.holes.push(shapes[s]);
                }
                var geometry = new THREE.ShapeGeometry(shape);

                // Resolve final opacity (element opacity × fillOpacity)
                var elemOpacity = parseFloat(path.userData.style.opacity);
                if (isNaN(elemOpacity)) elemOpacity = 1;
                var fillOpacity = parseFloat(path.userData.style.fillOpacity);
                if (isNaN(fillOpacity)) fillOpacity = 1;
                var finalOpacity = elemOpacity * fillOpacity;

                var material = new THREE.MeshBasicMaterial({
                    color: color,
                    transparent: finalOpacity < 1,
                    opacity: finalOpacity,
                    side: THREE.DoubleSide,
                    depthWrite: false
                });
                var mesh = new THREE.Mesh(geometry, material);
                mesh.userData.groupId = groupId;
                groupMap[groupId].push(mesh);
            });

            // Build flowerGroup from groupMap
            flowerGroup = new THREE.Group();
            Object.keys(groupMap).forEach(function(name) {
                var g = new THREE.Group();
                g.name = name;
                groupMap[name].forEach(function(m) {
                    g.add(m);
                    if (name === 'Petals') allPetalMeshes.push(m);
                    else if (name === 'Stigma') allStigmaMeshes.push(m);
                    else if (name === 'Stamens') allStamenMeshes.push(m);
                    else if (name === 'Anthers') allAntherMeshes.push(m);
                });
                flowerGroup.add(g);
            });

            // Scale flower
            flowerGroup.scale.set(svgScale, svgScale, svgScale);

            // Center the flower within its own coordinate space
            var box = new THREE.Box3().setFromObject(flowerGroup);
            var center = box.getCenter(new THREE.Vector3());
            flowerGroup.children.forEach(function(child) {
                child.position.sub(center);
            });

            container.add(flowerGroup);
            flowerGroup.visible = false;

            loaded = true;
            if (pendingFall) {
                flowerGroup.visible = true;
                pendingFall = false;
            }
        }

        //#explaining_the_function# Update physics state machine and Three.js transforms
        function updatePhysics(timestamp) {
            if (state === 'FROZEN') return;

            if (state === 'FALLING') {
                velocityY += GRAVITY;
                if (velocityY > TERMINAL_V) velocityY = TERMINAL_V;
                velocityX = Math.sin(timestamp * WIND_FREQ) * WIND_AMP;
                x += velocityX;
                y += velocityY;
                rotation += ROTATION_SPEED;
                if (y >= CENTER_Y) state = 'DAMPING';
            }

            if (state === 'DAMPING') {
                velocityY *= DAMPING;
                velocityX *= DAMPING;
                rotation += ROTATION_SPEED * 0.2;
                x += velocityX;
                y += velocityY;
                if (Math.abs(velocityY) < REST_DELTA && Math.abs(velocityX) < REST_DELTA) {
                    state = 'IDLE';
                }
            }

            if (state === 'IDLE') {
                rotation += ROTATION_SPEED * 0.15;
                x += Math.sin(timestamp * 0.0008) * IDLE_WIND_AMP * 0.02;
                y += Math.sin(timestamp * 0.001) * IDLE_BOB_AMP * 0.02;

                breathPhase = Math.sin(timestamp * 0.002) * 0.005;

                allStigmaMeshes.forEach(function(m) {
                    m.scale.x = 1;
                    m.scale.y = 1;
                    m.scale.z = 1 + breathPhase;
                });
            }

            // Apply physics to Three.js container
            if (loaded) {
                var worldPos = pixelToWorld(x, y);
                container.position.x = worldPos.x;
                container.position.y = worldPos.y;
                container.rotation.z = rotation * Math.PI / 180;
                container.scale.set(1, 1, 1);
            }
        }

        //#explaining_the_function# Animation loop — physics + render
        function tick(timestamp) {
            rafId = requestAnimationFrame(tick);
            updatePhysics(timestamp);
            render();
        }

        // --- Start ---
        document.addEventListener('DOMContentLoaded', function() {
            // Load SVG
            var loader = new SVGLoader();
            loader.load(
                'src/img/sakura.svg',
                function(data) { buildHierarchy(data); },
                undefined,
                function(err) { console.error('SVG load error:', err); }
            );

            // FROZEN → FALLING transition after 3s (preserved timing)
            setTimeout(function() {
                if (state === 'FROZEN') {
                    state = 'FALLING';
                    velocityY = 0.3;
                    if (loaded) {
                        flowerGroup.visible = true;
                    } else {
                        pendingFall = true;
                    }
                }
            }, 3000);

            // Start RAF loop
            rafId = requestAnimationFrame(tick);
        });

        // --- Resize handler (1:1 from official example) ---
        window.addEventListener('resize', function() {
            var width = window.innerWidth;
            var height = window.innerHeight;

            camera.aspect = width / height;
            camera.updateProjectionMatrix();

            renderer.setSize(width, height);

            CENTER_Y = window.innerHeight * (0.33 + Math.random() * 0.33);
        });
    </script>
</body>
</html>
